# =====================================================
# CONFIGURAÇÃO DE PRODUÇÃO - COOLIFY + HETZNER
# =====================================================

# Ambiente
NODE_ENV=production

# =====================================================
# DOMÍNIO E URLS
# =====================================================

# Substitua com seu domínio real
DOMAIN=seu-dominio.com
FRONTEND_URL=https://seu-dominio.com
BACKEND_URL=https://api.seu-dominio.com
NEXT_PUBLIC_API_URL=https://api.seu-dominio.com

# =====================================================
# BANCO DE DADOS
# =====================================================

# PostgreSQL no Docker Compose
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ml_gestao
DB_USER=mluser
DB_PASSWORD=MUDE_PARA_SENHA_FORTE_AQUI_123

# Connection string completa
DATABASE_URL=postgresql://mluser:MUDE_PARA_SENHA_FORTE_AQUI_123@postgres:5432/ml_gestao?sslmode=disable

# =====================================================
# MERCADO LIVRE API
# =====================================================

ML_APP_ID=SEU_APP_ID_AQUI
ML_SECRET=SEU_SECRET_AQUI
ML_REDIRECT_URI=https://seu-dominio.com/api/auth/ml/callback

# =====================================================
# SEGURANÇA
# =====================================================

# Gere com: openssl rand -base64 32
JWT_SECRET=GERE_UMA_CHAVE_SEGURA_COM_32_CARACTERES_MINIMO
SESSION_SECRET=OUTRA_CHAVE_SEGURA_DIFERENTE_DA_ANTERIOR_123

# =====================================================
# REDIS (CACHE)
# =====================================================

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# =====================================================
# PORTAS
# =====================================================

BACKEND_PORT=3001
FRONTEND_PORT=3000

# =====================================================
# FEATURES
# =====================================================

ENABLE_AUTO_RESPONSE=true
ENABLE_AUTO_REPUBLISH=true
ENABLE_CLAUDE_AI=true
ENABLE_TITLE_VARIATIONS=true

# =====================================================
# LIMITES
# =====================================================

MAX_STORES_PER_USER=10
MAX_AUTO_RESPONSES_PER_DAY=5000
MAX_REPUBLICATIONS_PER_DAY=200

# =====================================================
# LOGS E MONITORAMENTO
# =====================================================

LOG_LEVEL=info
ENABLE_METRICS=true

# =====================================================
# COOLIFY ESPECÍFICO
# =====================================================

# Coolify gerencia SSL automaticamente
COOLIFY_MANAGED=true
COOLIFY_AUTO_SSL=true