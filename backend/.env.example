# =====================================================
# CONFIGURAÇÃO DO AMBIENTE
# =====================================================
# Copie este arquivo para .env e configure com seus dados

# Ambiente (development ou production)
NODE_ENV=development

# =====================================================
# BANCO DE DADOS - ESCOLHA UMA OPÇÃO
# =====================================================

# Opção 1: PostgreSQL Local (desenvolvimento)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ml_gestao_dev
DB_USER=postgres
DB_PASSWORD=postgres

# Opção 2: SUPABASE (Recomendado - 500MB grátis)
# 1. Crie conta em https://supabase.com
# 2. Crie novo projeto
# 3. Vá em Settings > Database
# 4. Copie a Connection String:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT].supabase.co:5432/postgres

# Opção 3: NEON (3GB grátis)
# 1. Crie conta em https://neon.tech
# 2. Crie novo projeto
# 3. Copie a connection string:
# DATABASE_URL=postgresql://[user]:[password]@[endpoint]/[database]?sslmode=require

# =====================================================
# MERCADO LIVRE API
# =====================================================
ML_APP_ID=your_app_id
ML_SECRET=your_secret
ML_REDIRECT_URI=http://localhost:3001/api/auth/ml/callback

# =====================================================
# SERVIDOR
# =====================================================
PORT=3001
FRONTEND_URL=http://localhost:3000

# =====================================================
# SEGURANÇA
# =====================================================
JWT_SECRET=change-this-to-a-random-string-minimum-32-chars
SESSION_SECRET=another-random-string-for-sessions

# =====================================================
# FEATURES FLAGS
# =====================================================
ENABLE_AUTO_RESPONSE=true
ENABLE_AUTO_REPUBLISH=true
ENABLE_CLAUDE_AI=true
